{
    "compilerOptions": {
        "target": "ESNext",
        "module": "Node16",
        "moduleResolution": "node16",
        "strict": true,
        "noEmit": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "types": ["node"]
    },
    "include": ["index.ts", "src/**/*.ts", "tests/**/*.ts"]
}
